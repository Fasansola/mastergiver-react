generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  pendingEmail  String?
  password      String
  role          Role      @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile    Profile?
  accounts   Account[]
  sessions   Session[]
  onboarding OnboardingProgress?
  business   Business? // Phase 2: links user to their business profile

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// PROFILE (PHASE 1 — DO NOT MODIFY)
// ============================================

model Profile {
  id     String @id @default(cuid())
  userId String @unique

  firstName      String
  lastName       String
  username       String  @unique
  profilePicture String?

  state String?
  city  String?

  aboutMe  String? @db.Text
  whyIGive String? @db.Text

  status      ProfileStatus @default(DRAFT)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  causes        ProfileCause[]
  skills        ProfileSkill[]
  organizations ProfileOrganization[]

  @@map("profiles")
}

enum ProfileStatus {
  DRAFT
  PUBLISHED
}

// ============================================
// CAUSES (PHASE 1 — ONE PHASE 2 ADDITION)
// ============================================

model Cause {
  id    String  @id @default(cuid())
  name  String
  slug  String
  color String
  icon  String? // Optional — business panel causes have no icon

  source   CauseSource @default(PREDEFINED)
  panel    CausePanel  @default(INDIVIDUAL) // Which panel this cause belongs to
  isActive Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles      ProfileCause[]
  businesses    BusinessCause[] // Phase 2: allows businesses to link to causes
  impactRecords BusinessImpactRecord[] // Phase 2: impact record entries

  // Same name/slug is allowed in different panels
  @@unique([name, panel])
  @@unique([slug, panel])
  @@map("causes")
}

enum CauseSource {
  PREDEFINED
  USER_CUSTOM
}

enum CausePanel {
  INDIVIDUAL // Shown in the individual user onboarding/settings
  BUSINESS   // Shown in the business panel areas of impact
}

model ProfileCause {
  id        String @id @default(cuid())
  profileId String
  causeId   String

  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  cause   Cause   @relation(fields: [causeId], references: [id], onDelete: Cascade)

  @@unique([profileId, causeId])
  @@map("profile_causes")
}

// ============================================
// SKILLS (PHASE 1 — DO NOT MODIFY)
// ============================================

model Skill {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  source   SkillSource @default(PREDEFINED)
  isActive Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles ProfileSkill[]

  @@map("skills")
}

enum SkillSource {
  PREDEFINED
  USER_CUSTOM
}

model ProfileSkill {
  id        String @id @default(cuid())
  profileId String
  skillId   String

  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillId])
  @@map("profile_skills")
}

// ============================================
// ORGANIZATIONS (PHASE 1 — DO NOT MODIFY)
// ============================================

model Organization {
  id String @id @default(cuid())

  name String
  slug String @unique

  source      OrgSource
  pledgeOrgId String?   @unique

  ein      String?
  website  String?
  logo     String?
  mission  String? @db.Text
  location String?

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles ProfileOrganization[]

  @@map("organizations")
}

enum OrgSource {
  API
  MANUAL
}

model ProfileOrganization {
  id             String @id @default(cuid())
  profileId      String
  organizationId String

  createdAt DateTime @default(now())

  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([profileId, organizationId])
  @@map("profile_organizations")
}

// ============================================
// ONBOARDING (PHASE 1 — DO NOT MODIFY)
// ============================================

model OnboardingProgress {
  id     String @id @default(cuid())
  userId String @unique

  currentStep    Int     @default(1)
  completedSteps Int[]   @default([])
  isCompleted    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_progress")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  createdAt DateTime @default(now())

  @@unique([email, token])
  @@map("password_reset_tokens")
}

// ============================================
// BUSINESS PANEL (PHASE 2)
// ============================================

enum BusinessStatus {
  PENDING // Registered but has not paid yet
  ACTIVE // Payment confirmed, full access
  SUSPENDED // Payment failed or subscription cancelled
}

model Business {
  id        String         @id @default(cuid())
  slug      String         @unique
  ownerId   String         @unique
  owner     User           @relation(fields: [ownerId], references: [id])
  status    BusinessStatus @default(PENDING)
  published Boolean        @default(false)

  // --- About Us section ---
  logo        String?
  coverPhoto  String?
  companyName String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  aboutUs     String? @db.Text
  tagline     String?
  website     String?

  // --- Impact Summary section ---
  yearsOfInvolvement Int?
  totalContributions Decimal?
  activePartners     Int?

  // --- Stripe subscription fields ---
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Relations ---
  causes          BusinessCause[]
  partners        BusinessPartner[]
  communityEvents BusinessCommunityEvent[]
  endorsements    BusinessEndorsement[]
  offers          BusinessOffer[]
  impactRecords   BusinessImpactRecord[] // Section 8 — Impact Record

  @@map("businesses")
}

// Join table linking businesses to causes
// Mirrors the ProfileCause pattern from Phase 1
model BusinessCause {
  id         String @id @default(cuid())
  businessId String
  causeId    String

  createdAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  cause    Cause    @relation(fields: [causeId], references: [id], onDelete: Cascade)

  @@unique([businessId, causeId])
  @@map("business_causes")
}

// Stores individual community partner or program entries for a business
model BusinessPartner {
  id          String  @id @default(cuid())
  businessId  String
  image       String?
  name        String
  description String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_partners")
}

// Stores individual "In the Community" event/photo entries for a business
model BusinessCommunityEvent {
  id          String  @id @default(cuid())
  businessId  String
  photo       String?
  description String  @db.Text
  externalUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_community_events")
}

// Stores individual endorsement entries for a business
model BusinessEndorsement {
  id                   String  @id @default(cuid())
  businessId           String
  endorsingOrg         String
  endorserName         String?
  endorsementStatement String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_endorsements")
}

// Stores individual offer entries for a business
model BusinessOffer {
  id          String    @id @default(cuid())
  businessId  String
  title       String
  description String    @db.Text
  link        String?
  offerCode   String?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_offers")
}

// ---------------------------------------------------------------------------
// Section 8 — Impact Record (Phase 2)
// ---------------------------------------------------------------------------

enum ImpactType {
  ONE_TIME
  ONGOING
}

enum ContributionType {
  DONATION
  SPONSORSHIP
  VOLUNTEER_WORK
  EVENT_PROGRAM
  IN_KIND_SUPPORT
}

// Stores individual community impact log entries for a business
model BusinessImpactRecord {
  id               String            @id @default(cuid())
  businessId       String
  title            String
  causeId          String?
  organization     String?
  impactType       ImpactType
  startYear        Int
  endYear          Int?
  isPresent        Boolean           @default(false)
  contributionType ContributionType?
  amount           Decimal?
  details          String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  cause    Cause?   @relation(fields: [causeId], references: [id])

  @@map("business_impact_records")
}
