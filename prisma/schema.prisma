generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String
  role          Role      @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile    Profile?
  accounts   Account[]
  sessions   Session[]
  onboarding OnboardingProgress?

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// PROFILE
// ============================================

model Profile {
  id     String @id @default(cuid())
  userId String @unique

  firstName      String
  lastName       String
  username       String  @unique
  profilePicture String?

  state String?
  city  String?

  aboutMe  String? @db.Text
  whyIGive String? @db.Text

  status      ProfileStatus @default(DRAFT)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  causes        ProfileCause[]
  skills        ProfileSkill[]
  organizations ProfileOrganization[]

  @@map("profiles")
}

enum ProfileStatus {
  DRAFT
  PUBLISHED
}

// ============================================
// CAUSES
// ============================================

model Cause {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  color String
  icon  String

  source   CauseSource @default(PREDEFINED)
  isActive Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles ProfileCause[]

  @@map("causes")
}

enum CauseSource {
  PREDEFINED
  USER_CUSTOM
}

model ProfileCause {
  id        String @id @default(cuid())
  profileId String
  causeId   String

  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  cause   Cause   @relation(fields: [causeId], references: [id], onDelete: Cascade)

  @@unique([profileId, causeId])
  @@map("profile_causes")
}

// ============================================
// SKILLS
// ============================================

model Skill {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  source   SkillSource @default(PREDEFINED)
  isActive Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles ProfileSkill[]

  @@map("skills")
}

enum SkillSource {
  PREDEFINED
  USER_CUSTOM
}

model ProfileSkill {
  id        String @id @default(cuid())
  profileId String
  skillId   String

  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillId])
  @@map("profile_skills")
}

// ============================================
// ORGANIZATIONS
// ============================================

model Organization {
  id String @id @default(cuid())

  name String
  slug String @unique

  source      OrgSource
  pledgeOrgId String?   @unique

  ein     String?
  website String?
  logo    String?
  mission String? @db.Text

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles ProfileOrganization[]

  @@map("organizations")
}

enum OrgSource {
  API
  MANUAL
}

model ProfileOrganization {
  id             String @id @default(cuid())
  profileId      String
  organizationId String

  createdAt DateTime @default(now())

  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([profileId, organizationId])
  @@map("profile_organizations")
}

// ============================================
// ONBOARDING
// ============================================

model OnboardingProgress {
  id     String @id @default(cuid())
  userId String @unique

  currentStep    Int     @default(1)
  completedSteps Int[]   @default([])
  isCompleted    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_progress")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  createdAt DateTime @default(now())

  @@unique([email, token])
  @@map("password_reset_tokens")
}
